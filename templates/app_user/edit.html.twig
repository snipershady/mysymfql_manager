{% extends 'layouts/admin.html.twig' %}

{% block title %}Modifica utente — {{ app_user.username }}{% endblock %}
{% block page_title %}Modifica utente{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_user_index') }}">Utenti applicazione</a></li>
    <li class="breadcrumb-item"><a href="{{ path('app_user_show', {'id': app_user.id}) }}">{{ app_user.username }}</a></li>
    <li class="breadcrumb-item active">Modifica</li>
{% endblock %}

{% block content %}
<div class="row g-3">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="fa-solid fa-pen-to-square text-primary"></i>
                Modifica: {{ app_user.username }}
            </div>
            <div class="card-body">
                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                <div class="mb-3">
                    {{ form_label(form.username, 'Username', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.username, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.username) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.email, 'Email', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.email) }}
                </div>

                <div class="mb-3">
                    <span class="form-label fw-semibold d-block mb-2">
                        <i class="fa-solid fa-shield-halved me-1 text-muted"></i>Ruolo
                    </span>
                    <div class="d-flex flex-wrap gap-3">
                        {% for child in form.roles %}
                            <div class="form-check">
                                {{ form_widget(child, {'attr': {'class': 'form-check-input'}}) }}
                                {{ form_label(child, null, {'label_attr': {'class': 'form-check-label'}}) }}
                            </div>
                        {% endfor %}
                    </div>
                    {{ form_errors(form.roles) }}
                </div>

                <hr>

                <div class="mb-3">
                    {{ form_label(form.plainPassword, 'Nuova password', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.plainPassword, {'attr': {'class': 'form-control font-monospace'}}) }}
                    <div class="form-text text-muted">Lascia vuoto per non modificare la password.</div>
                    {{ form_errors(form.plainPassword) }}
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk me-1"></i>Salva modifiche
                </button>

                {{ form_end(form) }}
            </div>
            <div class="card-footer d-flex gap-2">
                <a href="{{ path('app_user_show', {'id': app_user.id}) }}" class="btn btn-outline-secondary btn-sm">
                    <i class="fa-solid fa-arrow-left me-1"></i>Annulla
                </a>
                <div class="ms-auto">
                    {{ include('app_user/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

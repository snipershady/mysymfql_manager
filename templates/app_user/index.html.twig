{% extends 'layouts/admin.html.twig' %}

{% block title %}Utenti applicazione{% endblock %}
{% block page_title %}Utenti applicazione{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active">Utenti applicazione</li>
{% endblock %}

{% block content %}
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between gap-2">
        <span>
            <i class="fa-solid fa-users-gear text-primary me-1"></i>
            Elenco utenti
        </span>
        <a href="{{ path('app_user_new') }}" class="btn btn-sm btn-primary">
            <i class="fa-solid fa-user-plus me-1"></i>Nuovo utente
        </a>
    </div>
    <div class="card-body">
        <table id="table-app-users" class="table table-hover align-middle w-100">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Ruoli</th>
                    <th class="text-end">Azioni</th>
                </tr>
            </thead>
            <tbody>
            {% for app_user in app_users %}
                <tr>
                    <td>{{ app_user.id }}</td>
                    <td>{{ app_user.username }}</td>
                    <td>{{ app_user.email }}</td>
                    <td>
                        {% for role in app_user.roles %}
                            <span class="badge bg-secondary">{{ role }}</span>
                        {% else %}
                            <span class="text-muted small">—</span>
                        {% endfor %}
                    </td>
                    <td class="text-end">
                        <a href="{{ path('app_user_show', {'id': app_user.id}) }}"
                           class="btn btn-sm btn-outline-secondary" title="Dettaglio">
                            <i class="fa-solid fa-eye"></i>
                        </a>
                        <a href="{{ path('app_user_edit', {'id': app_user.id}) }}"
                           class="btn btn-sm btn-outline-primary" title="Modifica">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">
                        <i class="fa-solid fa-circle-info me-2"></i>Nessun utente trovato
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block scripts_extra %}
{{ parent() }}

{% endblock %}

{% extends 'layouts/auth.html.twig' %}

{% block title %}Reset Password{% endblock %}

{% block card_title %}Reimposta la password{% endblock %}

{% block content %}
    {{ form_start(form) }}

        <div class="mb-4">
            <label for="{{ form.email.vars.id }}" class="form-label fw-semibold">
                <i class="fa-solid fa-envelope me-1 text-muted"></i> Email
            </label>
            {{ form_widget(form.email, {
                'attr': {
                    'class': 'form-control',
                    'placeholder': 'nome@esempio.com',
                    'autocomplete': 'email'
                }
            }) }}
            {{ form_errors(form.email) }}
            <div class="form-text text-muted mt-1">
                <i class="fa-solid fa-info-circle me-1"></i>Riceverai una password temporanea via email
            </div>
        </div>

        <div class="d-grid">
            <button type="submit" class="btn btn-primary btn-lg">
                <i class="fa-solid fa-paper-plane me-2"></i>{{ button_label|default('Invia richiesta') }}
            </button>
        </div>

    {{ form_end(form) }}
{% endblock %}

{% block auth_footer %}
    <div class="auth-footer">
        Ricordi la password? <a href="{{ path('app_login') }}">Accedi</a>
    </div>
{% endblock %}

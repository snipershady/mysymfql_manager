{% extends 'layouts/admin.html.twig' %}

{% block title %}Dashboard{% endblock %}
{% block page_title %}Dashboard{% endblock %}

{% block content %}

{# ── Server selector ── #}
<div class="row mb-4">
    <div class="col-md-5 col-lg-4">
        <label for="server-select" class="form-label fw-semibold text-muted small text-uppercase ls-1">
            <i class="fa-solid fa-server me-1"></i>Server MySQL
        </label>
        {% if sql_clients is empty %}
            <div class="d-flex align-items-center gap-3">
                <select class="form-select" disabled>
                    <option>Nessun server configurato</option>
                </select>
                <a href="{{ path('app_sql_client_new') }}" class="btn btn-primary btn-sm text-nowrap">
                    <i class="fa-solid fa-plus me-1"></i>Aggiungi
                </a>
            </div>
        {% else %}
            <select id="server-select" class="form-select">
                {% for client in sql_clients %}
                    <option value="{{ client.name }}" {% if loop.first %}selected{% endif %}>
                        {{ client.name }} — {{ client.host }}:{{ client.port }}
                    </option>
                {% endfor %}
            </select>
        {% endif %}
    </div>
</div>

{# ── Stat cards ── #}
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100" style="border-color:#0d6efd;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary"
                     style="width:48px;height:48px;flex-shrink:0;font-size:1.25rem;">
                    <i class="fa-solid fa-database"></i>
                </div>
                <div>
                    <div class="text-muted small">Database assegnati</div>
                    <div class="fw-bold fs-4" id="stat-db-count">—</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100" style="border-color:#198754;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center bg-success bg-opacity-10 text-success"
                     style="width:48px;height:48px;flex-shrink:0;font-size:1.25rem;">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <div>
                    <div class="text-muted small">Connessioni attive</div>
                    <div class="fw-bold fs-4" id="stat-connections">—</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100" style="border-color:#ffc107;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center bg-warning bg-opacity-10 text-warning"
                     style="width:48px;height:48px;flex-shrink:0;font-size:1.25rem;">
                    <i class="fa-solid fa-list-check"></i>
                </div>
                <div>
                    <div class="text-muted small">Processi in esecuzione</div>
                    <div class="fw-bold fs-4" id="stat-running">—</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100" style="border-color:#dc3545;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center bg-danger bg-opacity-10 text-danger"
                     style="width:48px;height:48px;flex-shrink:0;font-size:1.25rem;">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <div>
                    <div class="text-muted small">Processi bloccati</div>
                    <div class="fw-bold fs-4" id="stat-blocked">—</div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Database table + activity ── #}
<div class="row g-3">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="fa-solid fa-database text-primary"></i>
                I miei database
            </div>
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Nome database</th>
                            <th>Dimensione</th>
                            <th>Tabelle</th>
                            <th>Azioni</th>
                        </tr>
                    </thead>
                    <tbody id="table-databases-body">
                        {% if sql_clients is empty %}
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                <i class="fa-solid fa-circle-info me-2"></i>Nessun server configurato
                            </td>
                        </tr>
                        {% else %}
                        <tr id="row-loading">
                            <td colspan="4" class="text-center text-muted py-4">
                                <div class="spinner-border spinner-border-sm me-2" role="status"></div>Caricamento…
                            </td>
                        </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="fa-solid fa-clipboard-list text-primary"></i>
                Attività recente
            </div>
            <div class="card-body">
                <p class="text-muted text-center py-3 mb-0">
                    <i class="fa-solid fa-clock-rotate-left fa-2x d-block mb-2 opacity-25"></i>
                    Nessuna attività recente
                </p>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block scripts_extra %}
{{ parent() }}
{% if sql_clients is not empty %}
<script src="/asset/js/dashboard.js"></script>
{% endif %}
{% endblock %}

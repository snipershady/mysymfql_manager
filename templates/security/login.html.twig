{% extends 'layouts/auth.html.twig' %}

{% block title %}Accedi{% endblock %}

{% block card_title %}Accedi al tuo account{% endblock %}

{% block content %}
    {% if error %}
        <div class="alert alert-danger">
            <i class="fa-solid fa-circle-exclamation me-2"></i>
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    {% if app.user %}
        <div class="alert alert-info">
            <i class="fa-solid fa-circle-info me-2"></i>
            Sei già autenticato come <strong>{{ app.user.userIdentifier }}</strong>.
            <a href="{{ path('app_default') }}">Vai alla dashboard</a> oppure
            <a href="{{ logout_path() }}">esci</a>.
        </div>
    {% endif %}

    <form method="post" novalidate>
        <div class="mb-3">
            <label for="username" class="form-label fw-semibold">
                <i class="fa-solid fa-user me-1 text-muted"></i> Username
            </label>
            <input type="text"
                   value="{{ last_username }}"
                   name="_username"
                   id="username"
                   class="form-control"
                   autocomplete="username"
                   required
                   autofocus
                   placeholder="Inserisci il tuo username">
        </div>

        <div class="mb-4">
            <label for="password" class="form-label fw-semibold">
                <i class="fa-solid fa-lock me-1 text-muted"></i> Password
            </label>
            <input type="password"
                   name="_password"
                   id="password"
                   class="form-control"
                   autocomplete="current-password"
                   required
                   placeholder="Inserisci la tua password">
        </div>

        <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

        <div class="d-grid">
            <button class="btn btn-primary btn-lg" type="submit">
                <i class="fa-solid fa-right-to-bracket me-2"></i>Accedi
            </button>
        </div>
    </form>
{% endblock %}

{% block auth_footer %}
    <div class="auth-footer">
        Non hai un account? <a href="{{ path('app_register') }}">Registrati</a>
    </div>
{% endblock %}

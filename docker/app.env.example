# Copy this file to docker/app.env (gitignored) and fill in real values.
# docker-compose.yml loads it via env_file for the "app" service.
#
# Generate the secrets with:
#   php -r "echo bin2hex(random_bytes(32)).PHP_EOL;"                              # APP_SECRET / ALTCHAKEY
#   php -r "echo sodium_bin2hex(sodium_crypto_secretbox_keygen()).PHP_EOL;"       # SQLCLIENT_ENCRYPTION_KEY

APP_SECRET=CHANGE
SQLCLIENT_ENCRYPTION_KEY=CHANGE
ALTCHAKEY=CHANGE

# Application database (NOT the MySQL servers managed via the web UI).
# "db" is the bundled MySQL container started by docker-compose.yml. Point it
# at a remote host instead (and remove the "db" service) if you don't want a
# bundled database.
APP_DB_HOSTNAME=db
APP_DB_PORT=3306
APP_DB_NAME=mysymfql
APP_DB_USER=CHANGE
APP_DB_PASSWORD=CHANGE

# Bootstrap credentials for the bundled "db" container (official mysql image).
# MYSQL_DATABASE/MYSQL_USER/MYSQL_PASSWORD MUST match APP_DB_NAME/APP_DB_USER/
# APP_DB_PASSWORD above — only used on the very first start of an empty
# db_data volume. Unused if you removed the "db" service.
MYSQL_ROOT_PASSWORD=CHANGE
MYSQL_DATABASE=mysymfql
MYSQL_USER=CHANGE
MYSQL_PASSWORD=CHANGE

# Public URL used to generate absolute links (mails, CLI commands)
# The app is only served over HTTPS (see DOCKER.md), so this must start with https://
DEFAULT_URI=https://CHANGE

# Mailer (password reset, etc.)
MAILER_DSN=null://null
EMAIL_FROM=CHANGE

# Optional: CN used when auto-generating the self-signed TLS certificate.
# Set it to the real hostname/IP clients will use to reach the app.
# Ignored if you mount your own cert.pem/key.pem in /etc/apache2/ssl.
#SSL_CERT_CN=mysymfql.example.com

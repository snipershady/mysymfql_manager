# Copy this file to docker/app.env (gitignored) and fill in real values.
# docker-compose.yml loads it via env_file for the "app" service.
#
# Generate the secrets with:
#   php -r "echo bin2hex(random_bytes(32)).PHP_EOL;"                              # APP_SECRET / ALTCHAKEY
#   php -r "echo sodium_bin2hex(sodium_crypto_secretbox_keygen()).PHP_EOL;"       # SQLCLIENT_ENCRYPTION_KEY

APP_SECRET=CHANGE
SQLCLIENT_ENCRYPTION_KEY=CHANGE
ALTCHAKEY=CHANGE

# Application database (NOT the MySQL servers managed via the web UI) — remote host
APP_DB_HOSTNAME=CHANGE
APP_DB_PORT=3306
APP_DB_NAME=mysymfql
APP_DB_USER=CHANGE
APP_DB_PASSWORD=CHANGE

# Public URL used to generate absolute links (mails, CLI commands)
DEFAULT_URI=https://CHANGE

# Mailer (password reset, etc.)
MAILER_DSN=null://null
EMAIL_FROM=CHANGE
